{
  "display_information": {
    "name": "Issue Workflow",
    "description": "Collects and categorizes driver support issues via an interactive modal and posts reports to a Slack channel.",
    "background_color": "#2c2d30"
  },
  "features": {
    "bot_user": {
      "display_name": "Issue Workflow",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "views:open",
        "views:read",
        "views:write"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
